{
  "metadata": {
    "title": "Scenario demo — demand ensemble (daily)",
    "description": "A tiny self-contained runnable model that defines a pywr scenario. The 'demand' scenario has three members (low / mid / high); the Town's max_flow is a ConstantScenarioParameter, so each combination draws a different amount and the reservoir follows a different trajectory. Use the Runs tab scenario picker to view each member.",
    "minimum_version": "1.19.0",
    "author": "Shalini B"
  },
  "timestepper": {
    "start": "2000-01-01",
    "end": "2000-12-31",
    "timestep": 1
  },
  "scenarios": [
    {
      "name": "demand",
      "size": 3,
      "ensemble_names": ["low", "mid", "high"]
    }
  ],
  "nodes": [
    {
      "name": "Inflow",
      "type": "catchment",
      "flow": 80.0,
      "position": {
        "editor_position": [120, 100],
        "schematic": [120, 100]
      }
    },
    {
      "name": "Reservoir",
      "type": "reservoir",
      "max_volume": 300.0,
      "min_volume": 0.0,
      "initial_volume": 120.0,
      "cost": 0.0,
      "position": {
        "editor_position": [420, 100],
        "schematic": [420, 100]
      }
    },
    {
      "name": "Town",
      "type": "output",
      "max_flow": {
        "type": "constantscenario",
        "scenario": "demand",
        "values": [40.0, 70.0, 110.0]
      },
      "min_flow": 0.0,
      "cost": -100.0,
      "position": {
        "editor_position": [720, 40],
        "schematic": [720, 40]
      }
    },
    {
      "name": "Spill",
      "type": "output",
      "min_flow": 0.0,
      "cost": 0.0,
      "position": {
        "editor_position": [720, 220],
        "schematic": [720, 220]
      }
    }
  ],
  "edges": [
    ["Inflow", "Reservoir"],
    ["Reservoir", "Town"],
    ["Reservoir", "Spill"]
  ],
